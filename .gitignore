# Driver JDBC de MySQL — cada quien lo coloca localmente en WebContent/WEB-INF/lib
# Descargar de: https://dev.mysql.com/downloads/connector/j/
WebContent/WEB-INF/lib/*.jar

# Carpeta de clases compiladas que genera Eclipse — no se versiona
build/
WebContent/WEB-INF/classes/

# Configuración local específica de Eclipse (cada quien tiene la suya)
.settings/
.project
.classpath
.metadata/

# Archivos del sistema operativo
.DS_Store
Thumbs.db

# Archivos de IDE
.vscode/
.idea/

# Logs
*.log
